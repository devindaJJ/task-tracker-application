{
  "info": {
    "name": "Task Tracker API",
    "description": "Full endpoint coverage for the Task Tracker backend. Import the accompanying environment, then run requests top to bottom in the 'Auth' folder first -- the login request automatically saves tokens into environment variables that later requests reuse.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "{{base_url}}" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"full_name\": \"Alice Smith\",\n  \"password\": \"{{user_password}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Register Second User (for admin/RBAC testing)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"full_name\": \"Bob Jones\",\n  \"password\": \"{{user_password}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.environment.set('access_token', body.access_token);",
                  "pm.environment.set('refresh_token', body.refresh_token);",
                  "pm.test('Login returned tokens', () => {",
                  "    pm.expect(body.access_token).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.environment.set('access_token', body.access_token);",
                  "pm.environment.set('refresh_token', body.refresh_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User (/me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/users/me", "host": ["{{base_url}}"], "path": ["api", "v1", "users", "me"] }
          },
          "response": []
        },
        {
          "name": "List All Users (admin only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/users", "host": ["{{base_url}}"], "path": ["api", "v1", "users"] }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.environment.set('task_id', body.id);",
                  "pm.test('Task created with 201', () => {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/tasks", "host": ["{{base_url}}"], "path": ["api", "v1", "tasks"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write Q3 report\",\n  \"description\": \"Summarize quarterly performance\",\n  \"status\": \"todo\",\n  \"due_date\": \"2026-08-15\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "List Tasks (paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Tasks Filtered by Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks?status=todo",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"],
              "query": [{ "key": "status", "value": "todo" }]
            }
          },
          "response": []
        },
        {
          "name": "List Tasks Filtered by Owner (admin only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks?owner_id={{owner_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks"],
              "query": [{ "key": "owner_id", "value": "{{owner_id}}", "disabled": true }]
            },
            "description": "Set the `owner_id` environment variable to a real user UUID (e.g. from 'List All Users') before enabling this query param, then run as an admin. Leaving it empty/unset will 422 since owner_id must be a valid UUID."
          },
          "response": []
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "{{task_id}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Cases (for reviewer sanity-checking)",
      "item": [
        {
          "name": "Register Duplicate Email (expect 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"full_name\": \"Duplicate\",\n  \"password\": \"{{user_password}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Create Task Without Auth (expect 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/tasks", "host": ["{{base_url}}"], "path": ["api", "v1", "tasks"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Should fail\"\n}" }
          },
          "response": []
        },
        {
          "name": "Create Task With Empty Title (expect 422)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/tasks", "host": ["{{base_url}}"], "path": ["api", "v1", "tasks"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"\"\n}" }
          },
          "response": []
        },
        {
          "name": "List Users as Non-Admin (expect 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/users", "host": ["{{base_url}}"], "path": ["api", "v1", "users"] }
          },
          "response": []
        },
        {
          "name": "Get Nonexistent Task (expect 404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/tasks/00000000-0000-0000-0000-000000000000",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tasks", "00000000-0000-0000-0000-000000000000"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          },
          "response": []
        }
      ]
    }
  ]
}
